# Flask配置
SECRET_KEY=your-secret-key-here

# 打印API服务配置
PRINT_API_BASE_URL=http://localhost:12346
PRINT_API_TOKEN=TOKEN_PRINT_API_KEY_9527
PRINT_API_TIMEOUT=30

# 必需。队列名须与 lpstat -p 完全一致
# 推荐：惠普官方 ULD 队列 + 直连 ipp://打印机IP/ipp/print（如 HP_M437_ULD），驱动行为正确、可稳定出纸。
# driverless 链路程式上可能更快，但易出现 implicitclass/cups-browsed、文档不可用等问题，仅作备选。
DEFAULT_PRINTER_NAME=HP_M437_ULD
# 可选；多台打印机时英文逗号分隔。不设置时仅包含上面的默认打印机
# CONFIGURED_PRINTERS=HP_M437_ULD,Brother_DCP_L2550DW_series

# 默认进纸源（CUPS media-source）。auto 对多数驱动较通用；留空=不显式指定，用打印机自身默认
DEFAULT_MEDIA_SOURCE=auto

# 调试/排障=1：每次作业前 getPrinterAttributes（多一次 IPP，作业会变慢）
# CUPS_FETCH_PRINTER_ATTRS=

# 开发环境配置
FLASK_ENV=development
FLASK_DEBUG=True
